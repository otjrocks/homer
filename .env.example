# Configuration
# ========================
# Codex API endpoint URL
CODEX_API_URL=https://api.openai.com/v1

# API key for authentication with Codex endpoint (if required)
CODEX_API_KEY=your-codex-api-key

# Codex model name to use at the endpoint
CODEX_MODEL=codex-review

# GitLab Configuration
# ====================
# GitLab API token (create at: https://gitlab.com/profile/personal_access_tokens)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxx

# GitLab project ID (found in project settings)
GITLAB_PROJECT_ID=12345678

# GitLab URL (for self-hosted GitLab, use your instance URL)
GITLAB_URL=https://gitlab.com

# Base branch for MR comparison
BASE_BRANCH=main